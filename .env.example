# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FB_VERIFY_TOKEN=JAN_SEL_SECRET
FB_PAGE_ACCESS_TOKEN=

# Meta Conversions API (CAPI) - token del "System User" con permiso ads_management,
# generado en Meta Events Manager > tu Pixel > Configuración > Conversions API.
# Es DIFERENTE al FB_PAGE_ACCESS_TOKEN de arriba (ese es para la página, este es para el pixel).
META_CAPI_ACCESS_TOKEN=

# Admin Notifications (Comma-separated phone numbers, e.g., +573001234567,+573009876543)
ADMIN_WHATSAPP_NUMBERS=

# SendGrid Configuration
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# AI Configuration (NVIDIA NIM + OpenRouter). Se necesita AL MENOS una de las dos.
# NVIDIA se intenta primero (más barato/rápido); OpenRouter es el respaldo.
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

# Supabase Configuration
# Required for Cloud Production mode. If keys are missing, the system runs on Local Emulated Mode with automatic local database persistence.
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

GOOGLE_SHEETS_CSV_URL=
